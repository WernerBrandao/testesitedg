import { useState, useEffect } from 'react';
import { Button } from '@/components/ui/button';
import { Input } from '@/components/ui/input';
import { Textarea } from '@/components/ui/textarea';
import { Plus, Edit, Trash2, Eye, Star, Download, MousePointer, AlertTriangle } from 'lucide-react';
import { toast } from 'sonner';
import { trpc } from '@/lib/trpc';
import { format } from 'date-fns';

const AdminDashboard = () => {
  const [stats, setStats] = useState({
    news: 0,
    categories: 0,
    videos: 0,
    units: 0,
  });

  const { data: categories } = trpc.categories.list.useQuery();
  const { data: units } = trpc.units.list.useQuery();
  const { data: documents } = trpc.documents.list.useQuery();
  const { data: posts } = trpc.posts.list.useQuery();
  const { data: videos } = trpc.videos.list.useQuery();
  const { data: services } = trpc.services.getAll.useQuery();

  useEffect(() => {
    if (posts && categories && videos && units) {
      setStats({
        news: posts.filter(p => p.status === 'published').length ?? 0,
        categories: categories.length ?? 0,
        videos: videos.length ?? 0,
        units: units.length ?? 0,
      });
    }
  }, [posts, categories, videos, units]);

  const draftPosts = posts?.filter(p => p.status === 'draft') ?? [];
  const last5News = posts?.filter(p => p.status === 'published').sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()).slice(0, 5) ?? [];
  const last5Documents = documents?.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()).slice(0, 5) ?? [];
  const last5Services = services?.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime()).slice(0, 5) ?? [];

  return (
    <div className="p-6 bg-gray-50 min-h-screen">
      <h1 className="text-3xl font-bold mb-6" style={{ color: 'var(--degase-blue-dark)' }}>Dashboard Administrativo</h1>

      {/* Stats Grid */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
        <div className="bg-white p-4 rounded-lg shadow" style={{ borderColor: 'var(--degase-blue-light)', borderWidth: 1 }}>
          <h2 className="text-lg font-semibold">Notícias</h2>
          <p className="text-2xl font-bold" style={{ color: 'var(--degase-blue-dark)' }}>{stats.news}</p>
        </div>
        <div className="bg-white p-4 rounded-lg shadow" style={{ borderColor: 'var(--degase-blue-light)', borderWidth: 1 }}>
          <h2 className="text-lg font-semibold">Categorias</h2>
          <p className="text-2xl font-bold" style={{ color: 'var(--degase-blue-dark)' }}>{stats.categories}</p>
        </div>
        <div className="bg-white p-4 rounded-lg shadow" style={{ borderColor: 'var(--degase-blue-light)', borderWidth: 1 }}>
          <h2 className="text-lg font-semibold">Vídeos</h2>
          <p className="text-2xl font-bold" style={{ color: 'var(--degase-blue-dark)' }}>{stats.videos}</p>
        </div>
        <div className="bg-white p-4 rounded-lg shadow" style={{ borderColor: 'var(--degase-blue-light)', borderWidth: 1 }}>
          <h2 className="text-lg font-semibold">Unidades</h2>
          <p className="text-2xl font-bold" style={{ color: 'var(--degase-blue-dark)' }}>{stats.units}</p>
        </div>
      </div>

      {/* Draft Alert */}
      {draftPosts.length > 0 && (
        <div className="bg-yellow-100 border-l-4 border-yellow-500 text-yellow-700 p-4 mb-6" role="alert">
          <div className="flex items-center">
            <AlertTriangle className="w-5 h-5 mr-2" />
            <p>Existem {draftPosts.length} rascunhos de posts pendentes.</p>
          </div>
        </div>
      )}

      {/* Last 5 Published News */}
      <div className="bg-white p-4 rounded-lg shadow mb-6" style={{ borderColor: 'var(--degase-blue-light)', borderWidth: 1 }}>
        <h2 className="text-xl font-semibold mb-4" style={{ color: 'var(--degase-blue-dark)' }}>Últimas 5 Notícias Publicadas</h2>
        <table className="w-full table-auto">
          <thead>
            <tr className="bg-gray-100">
              <th className="px-4 py-2 text-left">Título</th>
              <th className="px-4 py-2 text-left">Data</th>
              <th className="px-4 py-2 text-left">Autor</th>
              <th className="px-4 py-2 text-left">Visibilidade</th>
              <th className="px-4 py-2 text-left">Views</th>
            </tr>
          </thead>
          <tbody>
            {last5News.map((news) => (
              <tr key={news.id} className="border-b">
                <td className="px-4 py-2">{news.title}</td>
                <td className="px-4 py-2">{format(new Date(news.createdAt), 'dd/MM/yyyy')}</td>
                <td className="px-4 py-2">{news.author?.name ?? 'Desconhecido'}</td>
                <td className="px-4 py-2">
                  <span className={`px-2 py-1 rounded text-xs ${news.visibility === 'public' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                    {news.visibility === 'public' ? 'Público' : 'Privado'}
                  </span>
                </td>
                <td className="px-4 py-2">{news.views ?? 0}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {/* Last 5 Added Documents */}
      <div className="bg-white p-4 rounded-lg shadow mb-6" style={{ borderColor: 'var(--degase-blue-light)', borderWidth: 1 }}>
        <h2 className="text-xl font-semibold mb-4" style={{ color: 'var(--degase-blue-dark)' }}>Últimos 5 Documentos Adicionados</h2>
        <table className="w-full table-auto">
          <thead>
            <tr className="bg-gray-100">
              <th className="px-4 py-2 text-left">Nome</th>
              <th className="px-4 py-2 text-left">Data</th>
              <th className="px-4 py-2 text-left">Visibilidade</th>
              <th className="px-4 py-2 text-left">Downloads</th>
            </tr>
          </thead>
          <tbody>
            {last5Documents.map((doc) => (
              <tr key={doc.id} className="border-b">
                <td className="px-4 py-2">{doc.name}</td>
                <td className="px-4 py-2">{format(new Date(doc.createdAt), 'dd/MM/yyyy')}</td>
                <td className="px-4 py-2">
                  <span className={`px-2 py-1 rounded text-xs ${doc.visibility === 'public' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                    {doc.visibility === 'public' ? 'Público' : 'Privado'}
                  </span>
                </td>
                <td className="px-4 py-2">{doc.downloads ?? 0}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {/* Last 5 Added Services */}
      <div className="bg-white p-4 rounded-lg shadow mb-6" style={{ borderColor: 'var(--degase-blue-light)', borderWidth: 1 }}>
        <h2 className="text-xl font-semibold mb-4" style={{ color: 'var(--degase-blue-dark)' }}>Últimos 5 Serviços Adicionados</h2>
        <table className="w-full table-auto">
          <thead>
            <tr className="bg-gray-100">
              <th className="px-4 py-2 text-left">Nome</th>
              <th className="px-4 py-2 text-left">Data</th>
              <th className="px-4 py-2 text-left">Visibilidade</th>
              <th className="px-4 py-2 text-left">Cliques</th>
            </tr>
          </thead>
          <tbody>
            {last5Services.map((service) => (
              <tr key={service.id} className="border-b">
                <td className="px-4 py-2">{service.name}</td>
                <td className="px-4 py-2">{format(new Date(service.createdAt), 'dd/MM/yyyy')}</td>
                <td className="px-4 py-2">
                  <span className={`px-2 py-1 rounded text-xs ${service.visibility === 'public' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800'}`}>
                    {service.visibility === 'public' ? 'Público' : 'Privado'}
                  </span>
                </td>
                <td className="px-4 py-2">{service.clicks ?? 0}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      {/* Audit Card */}
      <div className="bg-white p-4 rounded-lg shadow" style={{ borderColor: 'var(--degase-blue-light)', borderWidth: 1 }}>
        <h2 className="text-xl font-semibold mb-4" style={{ color: 'var(--degase-blue-dark)' }}>Auditoria</h2>
        <p className="text-gray-600">Estrutura base para implementação futura de auditoria.</p>
        {/* Placeholder for future audit features */}
      </div>
    </div>
  );
};

export default AdminDashboard;