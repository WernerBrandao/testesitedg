/* ============================================================
   VIDEOS
============================================================ */
function VideosSection() {
  const { data } = trpc.videos.getActive.useQuery({ 
    visibility: 'site'  // ✅ AÇÃO 3: Filtrar por visibilidade
  });
  const videos = Array.isArray(data) ? data : (data?.json ?? []);

  const featuredVideo = videos.find(v => v.isFeatured) || videos[0];

  const getYoutubeEmbedUrl = (url: string) => {
    const match = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]+)/);
    return match ? `https://www.youtube.com/embed/${match[1]}?rel=0` : url;
  };

  const defaultVideo = "https://www.youtube.com/embed/FkQqOZXU3xk?rel=0";

  return (
    <section className="py-10" style={{ backgroundColor: "var(--degase-gray-light)" }}>
      <div className="container">
        <h2 className="text-2xl md:text-3xl font-bold text-center mb-2 text-blue-600">Vídeos</h2>

        <div className="max-w-2xl mx-auto">
          <div className="aspect-video rounded-lg overflow-hidden shadow-lg">
            <iframe
              src={featuredVideo ? getYoutubeEmbedUrl(featuredVideo.youtubeUrl) : defaultVideo}
              title={featuredVideo?.title || "TV Degase"}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowFullScreen className="w-full h-full"
            />
          </div>
        </div>

        {videos.length > 1 && (
          <div className="mt-8 grid grid-cols-2 gap-4 max-w-2xl mx-auto">
            {videos.slice(1, 3).map(video => {
              const videoId = video.youtubeUrl?.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]+)/)?.[1];
              const thumb = video.thumbnailUrl || `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`;

              return (
                <a key={video.id} href={`https://www.youtube.com/watch?v=${videoId}`} target="_blank" className="group relative rounded-lg overflow-hidden shadow hover:shadow-lg transition-shadow">
                  <img src={thumb} alt={video.title} className="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-300" />
                  <div className="absolute inset-0 bg-black/40 group-hover:bg-black/50 flex items-center justify-center">
                    <Play size={32} className="text-white" />
                  </div>
                </a>
              );
            })}
          </div>
        )}

        <div className="text-center mt-6">
          <a href="https://www.youtube.com/@tvdegase" target="_blank">
            <Button variant="outline" className="border-2 text-xs font-semibold uppercase tracking-wider text-blue-900 border-blue-900">
              Veja todos os vídeos
            </Button>
          </a>
        </div>
      </div>
    </section>
  );
}

